DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,*.corpcore.app
SITE_BASE_DOMAIN=corpcore.localhost
PUBLIC_FRONTEND_BASE_URL=http://localhost:3000
TIME_ZONE=UTC

POSTGRES_DB=corpcore
POSTGRES_USER=corpcore
POSTGRES_PASSWORD=corpcore
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=noreply@corpcore.app
EMAIL_NOTIFICATIONS_ENABLED=1
# Optional override. Leave empty to auto-select:
# - sendgrid backend when SENDGRID_API_KEY is set
# - console backend otherwise (dev mode)
EMAIL_BACKEND=
# Optional SMTP fallback config
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0

WHATSAPP_API_BASE_URL=
WHATSAPP_API_TOKEN=

FEDAPAY_API_KEY=
FEDAPAY_ENV=sandbox
FEDAPAY_WEBHOOK_SECRET=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_S3_ENDPOINT_URL=

# ONLYOFFICE (GED : apercu Office) — meme secret que le service onlyoffice (JWT_ENABLED)
ONLYOFFICE_JWT_SECRET=onlyoffice-dev-secret
ONLYOFFICE_DOCUMENT_SERVER_URL=http://localhost:8089
# URL interne vue depuis le conteneur onlyoffice (telechargement du fichier)
OFFICE_FILE_DOWNLOAD_BASE=http://backend:8000
